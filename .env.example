# ==========================================
# ZeroPerson Auto - Environment Configuration
# Copy this file to .env and fill in your values
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret - Generate a strong random string (256-bit recommended)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Supabase Configuration (Cloud Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Vercel Deployment (optional)
VERCEL_URL=your-project.vercel.app
