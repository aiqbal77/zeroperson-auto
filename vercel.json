{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "server.js|middleware/**|routes/**|scripts/**|package.json|package-lock.json|.env.example"
    },
    "api/voice-webhook.js": {
      "includeFiles": "node_modules/@supabase/supabase-js/**"
    }
  },
  "env": {
    "SUPABASE_URL": "@supabase-url",
    "SUPABASE_KEY": "@supabase-key"
  },
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/tenants",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/data/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/crm/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/teasers/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/db-status",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/voice-webhook",
      "dest": "/api/voice-webhook.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}